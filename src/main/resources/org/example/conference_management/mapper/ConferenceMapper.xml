<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
                "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.conference_management.mapper.ConferenceMapper">
    <!--批量查询会议-->
    <select id="SelectByIds" resultType="org.example.conference_management.pojo.conference">
        select * from conference where conference_id in
        <foreach collection="conferenceIds" item="item" open="(" separator="," close=")">
            #{item}
        </foreach>
    </select>

</mapper>

